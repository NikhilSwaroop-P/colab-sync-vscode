{
  "name": "colab-sync-vscode",
  "displayName": "Colab Sync Control",
  "description": "Control panel for the colabd daemon and interactive GPU terminal launcher.",
  "version": "0.1.0",
  "publisher": "crimson-blitz",
  "repository": {
    "type": "git",
    "url": "https://github.com/crimson-blitz/colab-sync-vscode.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "*"
  ],
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "colab-sync-sidebar",
          "title": "Colab Sync",
          "icon": "$(sync)"
        }
      ]
    },
    "views": {
      "colab-sync-sidebar": [
        {
          "id": "colabSyncControl",
          "name": "Control Panel"
        }
      ]
    },
    "commands": [
      {
        "command": "colab-sync.startDaemon",
        "title": "Start Daemon",
        "icon": "$(play)"
      },
      {
        "command": "colab-sync.stopDaemon",
        "title": "Stop Daemon",
        "icon": "$(terminate)"
      },
      {
        "command": "colab-sync.linkWorkspace",
        "title": "Link Workspace",
        "icon": "$(link)"
      },
      {
        "command": "colab-sync.openTerminal",
        "title": "Open Colab Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "colab-sync.teardownSession",
        "title": "Kill Session",
        "icon": "$(trash)"
      },
      {
        "command": "colab-sync.provisionSession",
        "title": "Provision GPU Session",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "colab-sync.forceSync",
        "title": "Force Sync",
        "icon": "$(sync)"
      },
      {
        "command": "colab-sync.refreshView",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "colab-sync.openDashboard",
        "title": "Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "colab-sync.gitSync",
        "title": "Git Bulk Sync",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "colab-sync.configureGitHub",
        "title": "Configure GitHub Sync...",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "colab-sync.openDashboard",
          "when": "view == colabSyncControl",
          "group": "navigation@1"
        },
        {
          "command": "colab-sync.refreshView",
          "when": "view == colabSyncControl",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "colab-sync.startDaemon",
          "when": "view == colabSyncControl && viewItem == daemon-stopped",
          "group": "inline"
        },
        {
          "command": "colab-sync.stopDaemon",
          "when": "view == colabSyncControl && viewItem == daemon-running",
          "group": "inline"
        },
        {
          "command": "colab-sync.linkWorkspace",
          "when": "view == colabSyncControl && viewItem == link-unlinked",
          "group": "inline"
        },
        {
          "command": "colab-sync.openTerminal",
          "when": "view == colabSyncControl && viewItem == session-item",
          "group": "inline"
        },
        {
          "command": "colab-sync.teardownSession",
          "when": "view == colabSyncControl && viewItem == session-item",
          "group": "inline"
        }
      ]
    }
  }
}
